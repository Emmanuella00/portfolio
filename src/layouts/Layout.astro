---
import Nav from '../components/Nav.astro';
const { title = "Emmanuella Ikirezi" } = Astro.props;
---

<html lang="en">
  <head>
   <meta charset="UTF-8" />
   <meta name="viewport" content="width=device-width, initial-scale=1.0" />
   <meta name="description" content="Emmanuella Ikirezi — Software Engineer & Creative based in Kigali, Rwanda. Building at the intersection of technology, art, and culture." />
   <meta name="author" content="Emmanuella Ikirezi" />
   <meta name="keywords" content="Emmanuella Ikirezi, Software Engineer, Creative Developer, Kigali, Rwanda, VR AR, GURArt, KaziniKazi" />

   <!-- OG / Social -->
   <meta property="og:title" content="Emmanuella Ikirezi — Software Engineer & Creative" />
   <meta property="og:description" content="Building at the intersection of technology, art, and culture. Based in Kigali, Rwanda." />
   <meta property="og:image" content="/og-image.png" />
   <meta property="og:url" content="https://portfolio-emmaikirezi.vercel.app/" />
   <meta property="og:type" content="website" />

   <!-- Twitter -->
   <meta name="twitter:card" content="summary_large_image" />
   <meta name="twitter:title" content="Emmanuella Ikirezi — Software Engineer & Creative" />
   <meta name="twitter:description" content="Building at the intersection of technology, art, and culture. Based in Kigali, Rwanda." />
   <meta name="twitter:image" content="/og-image.png" />

   <title>{title}</title>
   <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body>
    <Nav />
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<script>
  import Lenis from '@studio-freight/lenis'
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  import { initAnimations } from '../scripts/animations'

  gsap.registerPlugin(ScrollTrigger)

  // Smooth scroll
  const lenis = new Lenis({
    duration: 1.2,
    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
  })

  function raf(time: number) {
    lenis.raf(time)
    ScrollTrigger.update()
    requestAnimationFrame(raf)
  }

  requestAnimationFrame(raf)

  // Init all animations
  initAnimations()
</script>