---
import Layout from '../layouts/Layout.astro';
---

<Layout>

  <!-- 01 HERO -->
  <section id="hero">
    <div class="hero-inner">
      <div class="hero-top">
        <p class="eyebrow">Software Engineer & Creative — Kigali, Rwanda</p>
        <p class="hero-index text-dust">01</p>
      </div>
      <h1 class="hero-title font-display">
        Emmanuella<br><em>Ikirezi.</em>
      </h1>
      <div class="hero-bottom">
        <p class="hero-sub">
          I build immersive digital experiences<br>that leave a real impact.
        </p>
        <div class="hero-cta">
          <a href="#work" class="btn-primary">View my work</a>
          <a href="#contact" class="btn-ghost">Get in touch</a>
        </div>
      </div>
    </div>
    <div class="hero-painting-wrap" id="paintingWrap">
      <img
        src="/hero-painting.jpg"
        alt=""
        class="hero-painting"
        id="heroParallaxImg"
        aria-hidden="true"
      />
      <div class="hero-painting-overlay"></div>
      <div class="hero-painting-overlay-bottom"></div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- 02 ABOUT -->
  <section id="about">
    <div class="about-inner">
      <div class="about-left">
        <div class="about-photo-wrap">
          <img
            src="/profile.jpeg"
            alt="Emmanuella Ikirezi"
            class="about-photo"
          />
          <div class="about-photo-overlay"></div>
        </div>
        <div class="about-photo-label">
          <p class="about-photo-name">Emmanuella Ikirezi</p>
          <p class="about-photo-location eyebrow">Kigali, Rwanda</p>
        </div>
      </div>
      <div class="about-right">
        <p class="eyebrow">02 — About</p>
        <p class="about-statement font-display">
          In a world that changes faster than yesterday, I believe technology is more than a tool — it's a mirror, a voice, and a medium for things we haven't yet imagined.
        </p>
        <p class="about-body">
          I'm Emmanuella — a software engineer and creative based in Kigali, Rwanda. That's what drew me to VR/AR, the frontier where experience and code become one.
        </p>
        <p class="about-body" style="margin-top: 16px;">
          But impact, to me, isn't abstract. It means showing up in people's lives in ways that actually matter. I build GURArt so Rwandan and African artists have a legitimate platform to reach real buyers. I build KaziniKazi so a plumber in Kigali doesn't have to rely on word of mouth to find work tomorrow.
        </p>
        <p class="about-quote font-display">
          "Building for the people who deserve it most."
        </p>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- 03 WORK -->
  <section id="work">
    <div class="work-header">
      <p class="eyebrow">03 — Work</p>
      <p class="section-count text-dust">3 projects</p>
    </div>
    <div class="projects-grid">

      <article class="project-card">
        <div class="project-top">
          <span class="project-num text-dust">01</span>
          <span class="project-tag">Marketplace</span>
        </div>
        <h2 class="project-title font-display">GURArt</h2>
        <p class="project-desc">
          A first-of-its-kind digital art marketplace tailored specifically for the Rwandan and African market. Connecting legitimate artists with real buyers.
        </p>
        <div class="project-footer">
          <span class="project-role eyebrow">Founder</span>
          <a href="https://gurart.vercel.app/" target="_blank" class="project-link">Visit ↗</a>
        </div>
      </article>

      <article class="project-card">
        <div class="project-top">
          <span class="project-num text-dust">02</span>
          <span class="project-tag">Platform</span>
        </div>
        <h2 class="project-title font-display">KaziniKazi</h2>
        <p class="project-desc">
          A job marketplace connecting informal sector workers — plumbers, carpenters, electricians — with employers across Rwanda. Replacing word-of-mouth with a reliable digital solution.
        </p>
        <div class="project-footer">
          <span class="project-role eyebrow">Fullstack Engineer</span>
        </div>
      </article>

      <article class="project-card">
        <div class="project-top">
          <span class="project-num text-dust">03</span>
          <span class="project-tag">Design & Dev</span>
        </div>
        <h2 class="project-title font-display">Momo App</h2>
        <p class="project-desc">
          A collaborative mobile money application built with the CodeCrafters team. Streamlining payments, transfers, and financial tracking for users.
        </p>
        <div class="project-footer">
          <span class="project-role eyebrow">Collaborator — Python</span>
        </div>
      </article>

    </div>
  </section>

  <div class="divider"></div>

  <!-- 04 SKILLS -->
  <section id="skills">
    <div class="skills-inner">
      <p class="eyebrow">04 — Skills</p>
      <div class="skills-grid">
        <div class="skills-col">
          <p class="skills-cat text-dust">Development</p>
          <ul class="skills-list">
            <li>Python</li>
            <li>JavaScript</li>
            <li>React</li>
            <li>Next.js</li>
            <li>Vue.js</li>
            <li>Astro</li>
          </ul>
        </div>
        <div class="skills-col">
          <p class="skills-cat text-dust">Craft</p>
          <ul class="skills-list">
            <li>GSAP</li>
            <li>Tailwind CSS</li>
            <li>VR / AR</li>
            <li>Figma</li>
            <li>Draw.io</li>
          </ul>
        </div>
        <div class="skills-col">
          <p class="skills-cat text-dust">Focus Areas</p>
          <ul class="skills-list">
            <li>Fullstack Engineering</li>
            <li>Creative Development</li>
            <li>Product Design</li>
            <li>Immersive Tech</li>
            <li>African Tech Ecosystems</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- 05 CONTACT -->
  <section id="contact">
    <div class="contact-inner">
      <p class="eyebrow">05 — Contact</p>
      <h2 class="contact-title font-display">
        Let's build<br><em>something real.</em>
      </h2>
      <p class="contact-sub">
        Open to collaborations, opportunities, and conversations.
      </p>
      <a href="mailto:emmakirezi@gmail.com" class="btn-primary" style="margin-top: 48px; display: inline-block; text-transform: none; letter-spacing: 0.05em;">
        EMAIL ME
      </a>
      <div class="contact-links">
        <a href="https://github.com/Emmanuella00" class="contact-social eyebrow">GitHub ↗</a>
        <a href="https://www.linkedin.com/in/emmanuella-ikirezi-16290528a/" class="contact-social eyebrow">LinkedIn ↗</a>
      </div>
    </div>
    <p class="footer-note text-dust">
      © 2026 Emmanuella Ikirezi — Kigali, Rwanda
    </p>
  </section>

</Layout>

<style>
  /* ── Hero ── */
  #hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 120px 32px 64px;
    position: relative;
    overflow: hidden;
  }

  .hero-inner { position: relative; z-index: 2; }

  .hero-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }

  .hero-index { font-size: 12px; letter-spacing: 0.1em; }

  .hero-title {
    font-size: clamp(56px, 12vw, 120px);
    line-height: 0.92;
    letter-spacing: -0.02em;
  }

  .hero-title em { color: var(--burnt); font-style: italic; }

  .hero-bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-top: 48px;
    gap: 32px;
    flex-wrap: wrap;
  }

  .hero-sub {
    font-size: 15px;
    color: var(--sand);
    line-height: 1.7;
    max-width: 360px;
  }

  .hero-cta { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }

  /* ── Hero Painting ── */
  .hero-painting-wrap {
    position: absolute;
    top: -20px;
    right: -20px;
    width: 480px;
    height: 560px;
    z-index: 1;
    overflow: hidden;
    border-radius: 2px;
    will-change: transform;
    transition: transform 1.2s cubic-bezier(0.23,1,0.32,1);
  }

  .hero-painting {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    will-change: transform;
    transition: transform 1.2s cubic-bezier(0.23,1,0.32,1);
  }

  .hero-painting-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      #0A0705 0%,
      rgba(10,7,5,0.6) 35%,
      rgba(10,7,5,0.1) 70%,
      rgba(10,7,5,0) 100%
    );
  }

  .hero-painting-overlay-bottom {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      #0A0705 0%,
      rgba(10,7,5,0.3) 35%,
      rgba(10,7,5,0) 65%
    );
  }

  /* ── Buttons ── */
  .btn-primary {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    background: var(--burnt);
    color: var(--cream);
    padding: 14px 28px;
    border-radius: var(--radius);
    display: inline-block;
    transition: opacity 0.3s ease;
  }

  .btn-primary:hover { opacity: 0.85; }

  .btn-ghost {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    background: transparent;
    color: var(--cream);
    padding: 13px 28px;
    border-radius: var(--radius);
    border: 0.5px solid var(--line);
    display: inline-block;
    transition: border-color 0.3s ease;
  }

  .btn-ghost:hover { border-color: var(--cream); }

  /* ── About ── */
  #about { padding: var(--space-xl) 32px; }

  .about-inner {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 80px;
    align-items: start;
  }

  .about-left {
    position: relative;
    width: 260px;
  }

  .about-photo-wrap {
    position: relative;
    width: 260px;
    height: 340px;
    overflow: hidden;
    border-radius: 2px;
  }

  .about-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    filter: grayscale(100%) contrast(1.05);
    transition: transform 0.6s ease;
  }

  .about-photo:hover { transform: scale(1.03); }

  .about-photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10,7,5,0) 50%,
      rgba(10,7,5,0.85) 100%
    );
  }

  .about-photo-label {
    padding: 14px 0 0;
    border-top: 0.5px solid var(--border);
    margin-top: 14px;
  }

  .about-photo-name {
    font-size: 13px;
    color: var(--cream);
    margin-bottom: 4px;
  }

  .about-photo-location { color: var(--olive); }

  .about-right { min-width: 0; }

  .about-statement {
    font-size: clamp(22px, 3.5vw, 38px);
    line-height: 1.15;
    color: var(--cream);
    margin-bottom: 32px;
    margin-top: 16px;
  }

  .about-body {
    font-size: 15px;
    color: var(--cream);
    opacity: 0.75;
    line-height: 1.8;
  }

  .about-quote {
    font-size: 20px;
    font-style: italic;
    color: var(--sand);
    border-left: 2px solid var(--olive);
    padding-left: 20px;
    margin-top: 40px;
  }

  /* ── Work ── */
  #work { padding: var(--space-xl) 32px; }

  .work-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 64px;
  }

  .section-count { font-size: 12px; letter-spacing: 0.1em; }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1px;
    background: var(--line);
    border: 0.5px solid var(--line);
  }

  .project-card {
    background: var(--bg);
    padding: 40px 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: background 0.4s ease;
  }

  .project-card:hover { background: var(--surface); }

  .project-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .project-num { font-size: 11px; letter-spacing: 0.1em; }

  .project-tag {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--burnt);
    border: 0.5px solid rgba(184,74,30,0.3);
    padding: 4px 10px;
    border-radius: var(--radius);
  }

  .project-title {
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1;
    color: var(--cream);
  }

  .project-desc {
    font-size: 14px;
    color: var(--dust);
    line-height: 1.75;
    flex: 1;
  }

  .project-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 8px;
    padding-top: 20px;
    border-top: 0.5px solid var(--border);
  }

  .project-link {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--burnt);
    transition: opacity 0.3s;
  }

  .project-link:hover { opacity: 0.7; }

  /* ── Skills ── */
  #skills { padding: var(--space-xl) 32px; }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 64px;
    margin-top: 48px;
  }

  .skills-cat {
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 0.5px solid var(--border);
  }

  .skills-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .skills-list li {
    font-size: 22px;
    font-family: var(--font-display);
    font-weight: 300;
    color: var(--cream);
    transition: color 0.3s ease;
  }

  .skills-list li:hover { color: var(--burnt); }

  /* ── Contact ── */
  #contact {
    padding: var(--space-xl) 32px var(--space-lg);
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .contact-inner { max-width: 800px; }

  .contact-title {
    font-size: clamp(48px, 8vw, 96px);
    line-height: 0.95;
    margin-top: 24px;
  }

  .contact-title em { color: var(--burnt); font-style: italic; }

  .contact-sub {
    font-size: 15px;
    color: var(--sand);
    margin-top: 24px;
  }

  .contact-links {
    display: flex;
    gap: 32px;
    margin-top: 40px;
    flex-wrap: wrap;
  }

  .contact-social {
    color: var(--dust);
    transition: color 0.3s ease;
  }

  .contact-social:hover { color: var(--cream); }

  .footer-note {
    font-size: 11px;
    letter-spacing: 0.1em;
    margin-top: auto;
    padding-top: 80px;
  }

  /* ── About Mobile ── */
  @media (max-width: 768px) {
    .about-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .about-left { width: 100%; }

    .about-photo-wrap {
      width: 100%;
      height: 280px;
    }

    .about-photo {
      object-position: center 20%;
    }

    #about { padding: var(--space-lg) 24px; }
  }

  /* ── Work Mobile ── */
  @media (max-width: 768px) {
    #work { padding: var(--space-lg) 24px; }

    .work-header { margin-bottom: 40px; }

    .projects-grid {
      grid-template-columns: 1fr;
      gap: 1px;
      background: var(--line);
      border: 0.5px solid var(--line);
    }

    .project-card {
      padding: 32px 24px;
      background: var(--bg);
      gap: 12px;
    }

    .project-title { font-size: 40px; }

    .project-desc {
      font-size: 13px;
      color: var(--dust);
      line-height: 1.75;
    }
  }

  /* ── Hero Mobile ── */
  @media (max-width: 768px) {
    #hero { padding: 100px 24px 48px; }

    .hero-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }

    .hero-painting-wrap {
      width: 100%;
      height: 260px;
      top: 0;
      right: 0;
      opacity: 0.25;
    }

    .hero-painting-overlay {
      background: linear-gradient(
        to bottom,
        rgba(10,7,5,0) 0%,
        #0A0705 75%
      );
    }

    .hero-painting-overlay-bottom { display: none; }
  }

  /* ── Global Mobile ── */
  @media (max-width: 768px) {
    #skills, #contact { padding: var(--space-lg) 24px; }
    .skills-grid { gap: 40px; }
    .contact-links { gap: 20px; }
  }
</style>